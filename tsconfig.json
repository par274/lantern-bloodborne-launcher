{
    "extends": "./.svelte-kit/tsconfig.json",
    "compilerOptions": {
        "allowJs": false,
        "checkJs": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "*.d.ts",
        "native/**/*.ts",
        "src/**/*.d.ts",
        "src/**/*.ts",
        "src/**/*.svelte",
        "vite.config.ts"
    ],
    "exclude": [
        "node_modules",
        ".build",
        "build",
        "dist",
        "release"
    ]
}
